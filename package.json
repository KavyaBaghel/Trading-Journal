{
  "name": "journall-trading-journal-app",
  "version": "1.0.0",
  "private": false,
  "description": "Deployable trading journal website and local desktop-style PWA with analytics, AI widgets, secure AI coach, calendar, goals, and journal pages.",
  "homepage": "https://kavyabaghel.github.io/Trading-Journal/",
  "type": "module",
  "main": "index.html",
  "scripts": {
    "start": "powershell -NoProfile -ExecutionPolicy Bypass -File ./local-server.ps1 -Root . -Port 8787",
    "serve": "powershell -NoProfile -ExecutionPolicy Bypass -File ./local-server.ps1 -Root . -Port 8787",
    "website": "powershell -NoProfile -ExecutionPolicy Bypass -File ./local-server.ps1 -Root . -Port 8787",
    "app": "wscript \"Journall App.vbs\"",
    "app:debug": "powershell -NoProfile -ExecutionPolicy Bypass -File ./launch-app.ps1",
    "chrome": "wscript \"Journall Chrome.vbs\"",
    "chrome:debug": "powershell -NoProfile -ExecutionPolicy Bypass -File ./launch-chrome-app.ps1",
    "mobile": "powershell -NoProfile -ExecutionPolicy Bypass -File ./start-mobile.ps1",
    "install-app": "powershell -NoProfile -ExecutionPolicy Bypass -File ./install-desktop-shortcut.ps1"
  },
  "keywords": [
    "trading-journal",
    "pwa",
    "ai-coach",
    "firebase-functions",
    "desktop-app",
    "website",
    "static-site",
    "github-pages",
    "trading-dashboard"
  ],
  "app": {
    "entry": "index.html",
    "localUrl": "http://127.0.0.1:8787/index.html",
    "launcher": "Journall App.vbs",
    "chromeLauncher": "Journall Chrome.vbs",
    "fallbackLauncher": "Journall App.bat",
    "installer": "Install App.bat",
    "openHere": "OPEN_APP_HERE.bat",
    "manifest": "manifest.webmanifest",
    "serviceWorker": "service-worker.js"
  }
}
